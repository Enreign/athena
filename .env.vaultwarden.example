# Copy to .env.vaultwarden.local and fill values.
# This file is git-ignored by design.

# Required for non-interactive Bitwarden login+unlock in restart-telegram.sh
BW_CLIENTID=""
BW_CLIENTSECRET=""
BW_MASTER_PASSWORD=""

# Optional overrides
# ATHENA_BW_KEYCHAIN_SERVICE="athena-vaultwarden"
# ATHENA_BW_KEYCHAIN_CLIENT_ID_ACCOUNT="BW_CLIENTID"
# ATHENA_BW_KEYCHAIN_CLIENT_SECRET_ACCOUNT="BW_CLIENTSECRET"
# ATHENA_BW_KEYCHAIN_MASTER_PASSWORD_ACCOUNT="BW_MASTER_PASSWORD"
# ATHENA_BW_KEYCHAIN_PATH="$HOME/Library/Keychains/login.keychain-db"
